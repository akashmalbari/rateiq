{
  "version": 2,
  "framework": null,
  "buildCommand": "cd frontend && npm ci --legacy-peer-deps && CI=false npm run build",
  "outputDirectory": "frontend/build",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/" }
  ]
}
